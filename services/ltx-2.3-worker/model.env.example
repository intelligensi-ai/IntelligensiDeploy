# LTX 2.3 model/runtime settings only.
# Host provider settings such as Lambda API keys, Nebius IPs, SSH keys, and
# registry auth belong in provider config, not in this model file.

LTX_MODEL_ID=Lightricks/LTX-2.3
LTX_MODEL_VARIANT=ltx-2.3-22b-distilled
LTX_ENGINE=ltx-2.3
LTX_BACKEND=ltx2
OUTPUT_DIR=/app/outputs

MAX_WIDTH=3840
MAX_HEIGHT=2160
MAX_FRAMES=100000
MAX_INFERENCE_STEPS=12
LTX_DTYPE=bfloat16
HF_HUB_ENABLE_HF_TRANSFER=1
HF_TOKEN=
