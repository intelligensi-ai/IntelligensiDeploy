# LTX model/runtime settings only.
# Provider host details such as NEBIUS_IP, SSH keys, and Lambda credentials
# belong in provider.nebius.env or the dashboard Lambda Config panel.

LTX_MODEL_ID=Lightricks/LTX-Video
LTX_ENGINE=ltx-video
LOW_VRAM=1
MAX_WIDTH=3840
MAX_HEIGHT=2160
MAX_FRAMES=100000
MAX_INFERENCE_STEPS=12
LTX_DTYPE=auto
HF_HUB_ENABLE_HF_TRANSFER=0
HF_TOKEN=
