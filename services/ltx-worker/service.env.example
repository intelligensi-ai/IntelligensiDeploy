PROVIDER=nebius
SERVICE_NAME=ltx-worker
NEBIUS_INSTANCE_NAME=intelligensi-ltx-worker
NEBIUS_INSTANCE_ID=
NEBIUS_IP=
NEBIUS_SERVICE_URL=
SERVICE_PORT=8000
SSH_USERNAME=ubuntu

# Optional registry settings. If LTX_REGISTRY_IMAGE is empty, deployment uses docker save/scp/docker load.
LTX_REGISTRY_IMAGE=ghcr.io/intelligensi-ai/ltx-worker:latest
LTX_REGISTRY_HOST=ghcr.io
LTX_REGISTRY_USERNAME=
LTX_REGISTRY_PASSWORD=

# Runtime settings.
LTX_MODEL_ID=Lightricks/LTX-Video
LTX_ENGINE=ltx-video
LOW_VRAM=1
MAX_WIDTH=256
MAX_HEIGHT=256
MAX_FRAMES=17
MAX_INFERENCE_STEPS=4
HF_TOKEN=

